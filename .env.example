# BMW E60 Coder Pro - Environment Variables Example
# Copy this file to .env and fill in your keys

# Google Gemini API Key for AI Tuning and DTC Analysis
# Get one at https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# App Configuration
VITE_APP_NAME="BMW E60 Coder Pro"
VITE_ENABLE_LIVE_TUNING=true
VITE_DEBUG_LOGGING=false
