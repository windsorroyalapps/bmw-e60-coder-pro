<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.bmwe60.coderpro.car">

    <!-- Android Auto permissions -->
    <uses-permission android:name="androidx.car.app.MAP_TEMPLATES" />
    <uses-permission android:name="androidx.car.app.NAVIGATION_TEMPLATES" />

    <application>
        <!-- Android Auto Car App Service -->
        <service
            android:name=".BMWCoderProCarAppService"
            android:exported="true"
            android:foregroundServiceType="connectedDevice"
            android:label="BMW E60 Coder Pro">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
            </intent-filter>
            <meta-data
                android:name="androidx.car.app.minCarApiLevel"
                android:value="1" />
        </service>

        <!-- Android Auto Intent Filter -->
        <activity
            android:name=".CarAppActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
